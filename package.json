{
  "name": "telegram-chat-exporter",
  "version": "1.2.3",
  "private": true,
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:standalone": "tsc -b && vite build --mode standalone",
    "preview": "vite preview --port 5176 --strictPort",
    "release": "pnpm version --tag-version-prefix=release/v -m \"chore(release): %s\n\n이 커밋에 release/v%s 태그가 붙는다. 태그가 올라가면 배포본 zip 과 사이트가\n여기서 함께 나가므로, 둘의 버전과 커밋이 같아진다.\"",
    "audit": "pnpm audit --audit-level=high"
  },
  "dependencies": {
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-select": "^2.3.3",
    "@tanstack/react-query": "^5.62.0",
    "big-integer": "^1.6.52",
    "clsx": "^2.1.1",
    "embla-carousel": "^8.6.0",
    "embla-carousel-autoplay": "^8.6.0",
    "fflate": "^0.8.3",
    "i18next": "^24.0.0",
    "i18next-browser-languagedetector": "^8.0.0",
    "libphonenumber-js": "^1.13.9",
    "lucide-react": "^0.474.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.0",
    "react-i18next": "^15.0.0",
    "react-router-dom": "^7.1.0",
    "tailwind-merge": "^2.6.0",
    "telegram": "2.26.21",
    "zod": "^3.24.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.1",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-plugin-node-polyfills": "^0.28.0"
  }
}
