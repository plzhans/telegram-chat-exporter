# 이 파일을 .env.local 로 복사해서 쓴다. Vite 가 자동으로 읽는다.
#
# 여기 있는 값은 전부 **선택 사항**이다. .env.local 이 아예 없어도 앱은 동작한다.
#
# VITE_ 접두사가 붙은 값은 **빌드 시점에 번들 안으로 박힌다.** 실행 중에 바꿀 수 없고
# 감춰지지도 않는다. 비밀로 지켜야 하는 값은 여기 두면 안 된다.
#
# 배포(GitHub Actions)에서는 이 파일을 쓰지 않는다. .env.local 은 gitignore 되어 있어
# CI 체크아웃에 존재하지 않고, 값은 워크플로가 직접 넣는다 —
# .github/workflows/deploy.yml 참고.

# ── 공용 api_id / api_hash ────────────────────────────────────────────────
#
# 값이 없으면 첫 화면에 "내 api_id 직접 입력"만 나오고, 있으면 "바로 시작" 선택지가 함께 뜬다.
# my.telegram.org/apps 에서 발급한다.
#
# 공개 배포에 공용 키를 넣을지는 정책 판단이다. 넣으면 UX 가 좋아지지만, 노출된 api_id 는
# 스팸에 재사용되기 쉽고 텔레그램이 폐기(API_ID_PUBLISHED_FLOOD)하면 전 사용자가 동시에
# 막힌다. 그때를 대비해 사용자가 자기 키를 넣는 경로는 항상 열려 있다.
#
# 배포본에 넣으려면 이 파일이 아니라
# Settings → Secrets and variables → Actions → **Variables** 에 같은 이름으로 넣는다.
# Secrets 가 아니라 Variables 인 이유는 위에 적은 대로 어차피 번들에 박히기 때문이다.
VITE_TELEGRAM_API_ID=
VITE_TELEGRAM_API_HASH=

# ── 소스 저장소 주소 ──────────────────────────────────────────────────────
#
# 화면 헤더와 안내 문구에 노출된다. "이 코드는 서버로 아무것도 보내지 않는다"는 주장을
# 사용자가 직접 검증할 수 있어야 하므로, 배포본과 같은 커밋이 올라가 있는 저장소를
# 가리켜야 한다.
#
# **배포에서는 건드릴 필요가 없다.** CI 가 자기 저장소 주소(github.server_url +
# github.repository)로 자동으로 채운다. 포크하거나 저장소를 옮겨도 알아서 따라간다.
# 여기 적는 값은 로컬 빌드에서 다른 주소를 보고 싶을 때만 쓴다.
# 비워 두면 src/shared/config/app.ts 의 기본값이 쓰인다.
VITE_GITHUB_REPO_URL=

# ── 첫 화면의 "내려받기" 버튼이 걸 주소 ──────────────────────────────────
#
# **둘 다 비워 두는 것이 정상이다.** 그러면 위 저장소의 GitHub 릴리스에서 아래 규칙으로
# 조립한다 - `<저장소>/releases/latest/download/telegram-exporter.zip`. 여기서 `latest`
# 는 태그 이름이 아니라 GitHub 가 "Latest 배지가 붙은 릴리스"로 풀어 주는 예약어라,
# 릴리스를 낼 때마다 사이트를 고칠 일이 없다.
#
# 릴리스 워크플로도 같은 규칙으로 에셋 이름을 정하므로(.github/workflows/release.yml),
# 비워 두면 사이트와 릴리스가 저절로 맞는다. 기본값은 src/landing/config.ts 에 있다.

# 배포처가 GitHub 가 아닐 때(자체 서버·CDN·S3 등) 주소를 통째로 넣는다. 값이 있으면
# 조립하지 않고 그대로 버튼에 걸린다.
VITE_RELEASE_DOWNLOAD_URL=

# 에셋 파일 이름만 바꾸고 싶을 때. 위 주소를 직접 넣었다면 쓰이지 않는다.
# **바꾸려면 저장소 Variables 에 넣어야 한다** - 사이트 빌드와 릴리스 워크플로가 같은
# 값을 봐야 하기 때문이다. 여기(.env)에만 적으면 로컬 빌드만 바뀐다.
VITE_RELEASE_ASSET_FILE_NAME=

# ── 이 도구가 올라가 있는 사이트 주소 ────────────────────────────────────
#
# 내보낸 zip 안의 index.html 하단에 링크로 적힌다. 파일만 건네받은 사람이 "이게 어디서
# 나온 것인가"를 따라갈 곳을 남기는 용도다.
#
# **배포에서는 건드릴 필요가 없다.** CI 가 Pages 설정의 실제 주소로 채운다.
# 비워 두면 내보낸 문서에 사이트 링크 줄이 아예 나오지 않는다 - 자체 호스팅이면
# 가리킬 사이트가 없는 게 정상이다.
VITE_SITE_URL=
